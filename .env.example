# ── Echo Tours 生产环境配置 ──────────────────────────────────────────
# 复制此文件为 .env 并填入真实值
#
# 后端配置 (后端 app.config.Settings 自动读取)
# ──────────────────────────────────────────

# 数据库 (必填)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/echo_tours
DATABASE_URL_SYNC=postgresql://user:password@host:5432/echo_tours

# Redis (必填)
REDIS_URL=redis://host:6379/0

# Elasticsearch (可选，用于搜索)
ELASTICSEARCH_URL=http://host:9200

# JWT 密钥 (必填 - 生产环境务必更换为随机长字符串)
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stripe 支付 (可选 — 未配置时使用 mock)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_live_...

# Google OAuth (可选 — 未配置时前端显示 Dev Mode Google 登录按钮)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# SendGrid 邮件 (可选)
SENDGRID_API_KEY=SG.xxx

# CORS
CORS_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── 前端配置 (NEXT_PUBLIC_ 前缀) ──────────────────────────────────

# API 地址 (生产环境通常为相对路径或同域)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
